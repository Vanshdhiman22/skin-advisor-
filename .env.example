# Copy this file to ".env" and fill in your key, OR set the variables in your terminal.
# Without a key the app still runs: the scan uses a quick guided flow instead of AI vision.

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Models ---
# Groq rotates its model lineup often (models get deprecated). If you see a
# "model not found" or "deprecated" error, get a current id from
# https://console.groq.com/docs/models and update the value below.

# Text model (chat + guided matching)
TEXT_MODEL=openai/gpt-oss-120b

# Vision model (the photo scan). Must be a vision-capable model.
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
